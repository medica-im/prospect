# Django
DJANGO_SECRET_KEY=generate-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=prospect.yourdomain.com,web
CSRF_TRUSTED_ORIGINS=https://prospect.yourdomain.com
CORS_ALLOWED_ORIGINS=https://prospect.yourdomain.com

# PostgreSQL
POSTGRES_DB=prospect
POSTGRES_USER=prospect
POSTGRES_PASSWORD=generate-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DATA=

# RabbitMQ
RABBITMQ_USER=prospect
RABBITMQ_PASSWORD=generate-a-strong-password

# Ports (localhost only, for external nginx)
DJANGO_PORT=8000
FRONTEND_PORT=3000

# Celery (CELERY_BROKER_URL is set in docker-compose from RABBITMQ_USER/PASSWORD)
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Mailgun
MAILGUN_API_URL=https://api.eu.mailgun.net/v3/mail.yourdomain.com/messages
MAILGUN_SENDING_KEY_ID=
MAILGUN_SENDING_KEY=
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_FROM_EMAIL=Your Name <noreply@mail.yourdomain.com>

# Twenty CRM
TWENTY_API_URL=https://twenty.yourdomain.com
TWENTY_API_KEY=

# IMAP (Dovecot)
IMAP_SERVER=mail.yourdomain.com
IMAP_EMAIL=
IMAP_PASSWORD=
